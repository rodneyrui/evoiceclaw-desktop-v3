# eVoiceClaw Desktop v3 — Secrets Template
# Copy this file to secrets.yaml and fill in your API keys
# NEVER commit secrets.yaml to version control!

# ─── Default LLM API Key ───
llm:
  api_key: ""                           # Your default provider's API key

# ─── Provider API Keys ───
providers:
  openai:
    api_key: ""                         # https://platform.openai.com/api-keys
  anthropic:
    api_key: ""                         # https://console.anthropic.com/
  google:
    api_key: ""                         # https://aistudio.google.com/apikey
  deepseek:
    api_key: ""                         # https://platform.deepseek.com/api_keys
  zhipu:
    api_key: ""                         # https://open.bigmodel.cn/
  tongyi:
    api_key: ""                         # https://dashscope.console.aliyun.com/
  kimi:
    api_key: ""                         # https://platform.moonshot.cn/
  baichuan:
    api_key: ""                         # https://platform.baichuan-ai.com/

# ─── External Services ───
services:
  bocha:
    api_key: ""                         # https://open.bochaai.com/ (Chinese web search)
